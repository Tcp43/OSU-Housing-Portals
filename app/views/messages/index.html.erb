<%# File created 11/24 by Troy Paschal:Display chat box%>
<h1>Your Chat</h1>

<div id="chat-box">
  <% if @messages&.any? %>
    <% @messages.each do |message| %>
      <div class="<%= message.sender == current_user ? 'my-message' : 'their-message' %>">
        <strong><%= message.sender&.name %>:</strong> <%= message.body %>
        <small><%= message.created_at.strftime("%b %d, %Y %H:%M") %></small>
      <% if message.sender == current_user %>
          <%= button_to "Delete", conversation_message_path(@conversation, message),method: :delete, data: { confirm: "Are you sure you want to delete this message?" },class: "btn btn-danger btn-sm" %>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <p>No messages yet.</p>
  <% end %>
</div>

<%= form_with model: [@conversation, Message.new], local: true do |f| %>
  <div class="mb-3">
    <%= f.text_area :body, placeholder: "Type your message...", rows: 3, class: "form-control" %>
  </div>
  <div class="d-flex align-items-center gap-2">
    <%= link_to "Back to conversations", conversations_path, class: "generic-button" %>
    <%= f.submit "Send Message", class: "new-button" %>
  </div>
<% end %>

