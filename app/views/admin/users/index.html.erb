<h1 class="text-center mb-4">All Users</h1>

<table class="table table-bordered table-hover">
  <thead class="thead-dark">
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Role</th>
      <th>Created At</th>
      <th>Email Status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.name %></td>
        <td><%= user.email %></td>
        <td>
          <%= form_with model: user, url: update_user_role_admin_user_path(user), method: :patch, local: true do |f| %>
            <%= f.select :role, ["student", "admin", "landlord", "manager"], { selected: user.role }, { class: "form-select" } %>
            <%= f.submit "Update", class: "btn btn-sm btn-primary ml-2" %>
          <% end %>
        </td>
        <td><%= user.created_at.strftime("%B %d, %Y") %></td>
        <td>
          <% if user.confirmed_at.nil? %>
            <span class="text-warning">Pending</span>
          <% else %>
            <span class="text-success">Confirmed</span>
          <% end %>
        </td>
        <td>
          <%= link_to "Delete", delete_user_admin_user_path(user), data: { turbo_confirm: "Are you sure?", "turbo_method": :delete }, class: "btn btn-sm btn-danger" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
