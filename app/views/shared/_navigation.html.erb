<%# File created 11/20/2024 by Koury Harmon %>
<%# Navigation bar %>
<nav class="navbar nav navbar-dark bg-dark fixed-top navbar-expand-lg">
  <div class="container-fluid">
    <%= link_to "OSU Off-Campus Housing Portal", home_path, class:"navbar-brand fs-3", id:"logo"%>
    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <% if user_signed_in? %>
          <li class="nav-item"><%= link_to "Messages", conversations_path, class: "nav-link" %></li>
          <% if current_user.student? || current_user.admin? || current_user.manager? %>
            <li class="nav-item"><%= link_to "House Search", student_search_path, class: "nav-link"  %></li>
            <li class="nav-item"><%= link_to "Favorites", student_profile_path(current_user.id), class: "nav-link" %></li>
          <% end %>  
          <% if current_user.landlord? || current_user.admin? || current_user.manager?%>
            <li class="nav-item"><%= link_to "My Properties", landlord_profile_path(current_user.id), class: "nav-link" %></li>
            <li class="nav-item"><%= link_to 'Post a Property', new_listing_path, class: 'nav-link' %> </li>
          <% end %>
          <%# Admin Link for managing users %>
          <% if current_user.admin? %>
            <li class="nav-item"><%= link_to "Manage Users", admin_users_path, class: "nav-link" %></li>
          <% end %>
        <% end %>
      </ul>
      <%# Created 11/28/2024 by Yuxi Lin %>
      <%# Session management links %>
      <ul class="navbar-nav justify-content-end">        
        <% if user_signed_in? %>
        <%# Dropdown menu for session management %>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <%= current_user.name %>
          </a>
          <ul class="dropdown-menu dropdown-menu-lg-end">
            <li><%= link_to "Edit profile", edit_user_registration_path, class: "dropdown-item"%></li>
            <li><%= link_to "Sign Out", destroy_user_session_path, data: { "turbo_method": :delete }, class: "dropdown-item"%></li>
          </ul>
        </li>
        <% else %>
          <li class="nav-item"><%= link_to "Sign up", new_user_registration_path, class: "nav-link" %></li>
          <li class="nav-item"><%= link_to "Login", new_user_session_path, class: "nav-link" %></li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>
