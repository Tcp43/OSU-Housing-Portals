<%# File created 11/23 by Troy Paschal:Displays a list of all chats%>
<h1 class="text-center mb-4">Messages</h1>

<% if @conversations.any? %>
  <div class="conversation-list">
    <% @conversations.each do |conversation| %>
      <div class="conversation-item border p-3 mb-4">
        <!-- Conversation Header -->
        <div class="conversation-header d-flex justify-content-between align-items-center">
          <div>
            Chat with 
            <% if conversation.sender == current_user %>
              <strong><%= conversation.recipient.name %></strong>
            <% else %>
              <strong><%= conversation.sender.name %></strong>
            <% end %>
          </div>

          <!-- Delete Conversation Button -->
          <div>
            <%= button_to "<i class='bi bi-trash'></i> Delete Chat".html_safe, conversation_path(conversation), method: :delete, 
                        data: { turbo_confirm: "Are you sure you want to delete this conversation and all its messages?" },
                        class: "delete-button" %>
          </div>
        </div>

        <!-- Chat Box -->
        <div id="chat-box-<%= conversation.id %>" class="chat-box mt-3">
          <h4 class="chat-title">Messages</h4>
          <% messages = conversation.messages.order(created_at: :asc) %>
          <% if messages.any? %>
            <% messages.each do |message| %>
              <div class="<%= message.sender == current_user ? 'my-message' : 'their-message' %> mb-2">
                <strong><%= message.sender.name %>:</strong> <%= message.body %>
              </div>
            <% end %>
          <% else %>
            <p class="no-messages text-muted">No Previous Messages</p>
          <% end %>
        </div>

        <!-- Message Form -->
        <div class="message-form mt-3">
          <%= form_with model: [conversation, Message.new], local: true do |f| %>
            <div class="message-input">
              <%= f.text_area :body, placeholder: "Type your message...", rows: 2, class: "form-control" %>
            </div>
            <div class="message-submit mt-2">
              <%= f.submit "Send Message", class: "generic-button btn-sm" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-center text-muted">No chats found</p>
<% end %>

<div class="text-center mt-4">
  <%= link_to "<i class='bi bi-chat-dots'></i> Start a New Chat".html_safe, new_conversation_path, class: "new-button btn-lg" %>
</div>
<br>