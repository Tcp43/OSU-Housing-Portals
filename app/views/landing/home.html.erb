<%# Created 11/20/2024 by Koury Harmon: Home page for non signed in users %>
<%# Edited 11/29/2024 by Koury Harmon: Separate home page for users who are and arent signed in%>
<% if !user_signed_in?%>
  <% provide(:title, "Home") %>
  <div class="p-4 mb-4 border bg-body-tertiary bg-secondary rounded-3 text-center">
    <h1>Welcome to the OSU Off-Campus Housing Portal</h1>
    <h2>This website is used to help you find potential off-campus housing and provide you with connections to landlords. Please sign in to view listings!</h2>
    <div class="d-flex justify-content-center gap-2">
      <%= link_to "Log In", new_user_session_path, class: "session-button" %>
      <%= link_to "Sign Up", new_user_registration_path, class: "session-button" %>
    </div>
  </div>
  <% @listings.first(3).each do |listing| %>
    <%= render listing %>
  <% end %>
<% end %>