<%# Edit the Property info of a listing %>
<div class="row">
  <!-- Sidebar Column -->
  <div class="col-md-3">
    <%= render 'listings/sidebar' %>
  </div>

  <!-- Form Column -->
  <div class="col-md-9">
    <h2>Step 2: Property Info</h2>
    <p>Properties that list amenities get rented faster!</p>

    <%= form_with(model: @listing, url: save_step2_listing_path(@listing), method: :post) do |form| %>
      <!-- Bedroom Input -->
      <div class="form-group">
        <%= form.label "Number of bedrooms" %>
        <div class="input-group">
          <%= form.select :bedroom, 
              options_for_select((1..10).map { |i| [i, i] }),
              {}, 
              class: "form-control" 
          %>
          <div class="input-group-append">
            <span class="input-group-text">▼</span>
          </div>
        </div>
      </div>

      <!-- Bathroom Input -->
      <div class="form-group">
        <%= form.label "Number of bathrooms" %>
        <div class="input-group">
          <%= form.select :bathroom, 
              options_for_select((1..10).map { |i| [i, i] }),
              {}, 
              class: "form-control" 
          %>
          <div class="input-group-append">
            <span class="input-group-text">▼</span>
          </div>
        </div>
      </div>

      <!-- Square Footage Input -->
      <div class="form-group">
        <%= form.label "Square footage (optional)" %>
        <%= form.text_field :square_footage, class: "form-control" %>
      </div>

      <!-- Property Description -->
      <div class="form-group">
        <%= form.label :description, "Property Description" %>
        <%= form.text_area :description, class: "form-control", rows: 5, maxlength: 500, id: "description", placeholder: "e.g., Spacious 2-bedroom apartment with hardwood floors, modern kitchen, and great city view..." %>
        <small id="char-count" class="form-text text-muted">500 characters remaining</small>
      </div>

      <div class="form-group custom-file-upload">
        <%= form.label :cover_image, class: "form-label" %>
        <%= form.file_field :cover_image, direct_upload: true, class: "form-control custom-file-input" %>
        <div class="custom-file-preview">
          <p>No file chosen yet.</p>
          <img id="coverImagePreview" class="img-preview" style="display: none;" />
        </div>
      </div>

      <!-- Amenities Selection -->
      <h4>List Your Property's Amenities</h4>
      <p>Select any that apply:</p>
      <div class="form-group">
        <%= form.check_box :amenities, { multiple: true }, 'Air conditioning', nil %> Air conditioning <br>
        <%= form.check_box :amenities, { multiple: true }, 'Dishwasher', nil %> Dishwasher <br>
        <%= form.check_box :amenities, { multiple: true }, 'Washer & dryer in unit', nil %> Washer & dryer in unit <br>
        <%= form.check_box :amenities, { multiple: true }, 'Refrigerator', nil %> Refrigerator <br>
        <%= form.check_box :amenities, { multiple: true }, 'Yard', nil %> Yard <br>
        <%= form.check_box :amenities, { multiple: true }, 'Furnished', nil %> Furnished <br>
      </div>
      <br>
      <%# Submit buttons %>
      <%= link_to '<i class="bi bi-arrow-bar-left"></i> Go Back'.html_safe, :back, class: "generic-button" %>
      <%= button_tag '<i class="bi bi-save"></i> Save and Exit'.html_safe, name: 'exit', type: 'submit', class: 'generic-button' %>
      <%= button_tag '<i class="bi bi-arrow-right-square"></i> Save and Next'.html_safe, name: 'next', type: 'submit', class: 'new-button' %>
    <% end %>
  </div>
</div>

<%# Include JavaScript for this specific view %>
<%= javascript_include_tag 'character_counter', 'data-turbolinks-track': 'reload' %>
