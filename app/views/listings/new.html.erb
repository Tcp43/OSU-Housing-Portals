<% content_for :title, "New listing" %>

<div class="container mt-5">
  <h1>Post Your Property</h1>
  <p>Welcome to our property listing service!</p>
  
  <p>Give a name for your property.</p>

  <%= form_for @listing do |f| %>
    <div class="form-group">
      <%= f.label :name, "Property Name" %>
      <%= f.text_field :name, class: "form-control" %>
    </div>

    <!-- Button Group -->
    <div class="d-flex justify-content-start align-items-center mt-3 gap-2">
      <%= link_to '<i class="bi bi-arrow-bar-left"></i> Go Back'.html_safe, :back, class: "generic-button" %>
      <%= button_tag '<i class="bi bi-rocket-takeoff"></i> Get Started'.html_safe, type: 'submit', class: "new-button" %>
    </div>
  <% end %>
</div>
